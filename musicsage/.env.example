# ──────────────────────────────────────────────────────────────────────────────
# MusicSage — variáveis de ambiente
#
# Desenvolvimento local (fora do Docker):
#   cp .env.example .env  →  edite o .env
#
# Docker / NAS:
#   Passe as vars via: docker run -e PLEX_URL=... -e PLEX_TOKEN=...
#   Ou use um docker-compose.yml com env_file ou environment:
# ──────────────────────────────────────────────────────────────────────────────

# ── Servidor ──────────────────────────────────────────────────────────────────
MUSICSAGE_PORT=3002

# ── Plex ──────────────────────────────────────────────────────────────────────
# URL do Plex Media Server.
# No Docker da mesma host: use o IP do gateway (ex: 172.17.0.1)
# Em docker-compose com rede compartilhada: use o nome do serviço
PLEX_URL=http://192.168.1.100:32400

# Token de autenticação do Plex
# Obtenha em: Settings → Account → XML (X-Plex-Token)
PLEX_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx

# ── Ollama (LLM local) ────────────────────────────────────────────────────────
# URL do servidor Ollama onde os modelos LLM estão a rodar
OLLAMA_URL=http://192.168.1.100:11434

# Modelo padrão para recomendações e análise de mood/gênero
# Opções testadas: gemma4:e4b | deepseek-r1:1.5b | llama3.2:3b
OLLAMA_DEFAULT_MODEL=gemma4:e4b

# Modelo de embeddings para clustering e playlist semântica
# Pré-instalar no Ollama: ollama pull nomic-embed-text
EMBEDDING_MODEL=nomic-embed-text

# ── Mídia ─────────────────────────────────────────────────────────────────────
# Raiz local onde toda a mídia está montada.
# O Plex retorna paths como /music/Artist/song.flac ou /movies/Film/film.mkv
# e eles são resolvidos diretamente: /media + /music/Artist/song.flac → /media/music/Artist/song.flac
# Monte o share do NAS: -v /nas/media:/media
PLEX_MEDIA_PATH=/media

# ── Dados persistentes ────────────────────────────────────────────────────────
# Diretório raiz para cache de análises, embeddings e playlists
# Monte um volume persistente: -v /nas/musicsage-data:/data
DATA_DIR=/data

# Diretório de logs (padrão: DATA_DIR/logs)
# Monte um volume: -v /nas/musicsage-data/logs:/data/logs
LOG_DIR=/data/logs

# ── Agents irmãos (opcional — só necessário para a aba Downloads) ────────────
# Se os agents não estiverem montados, a aba Downloads mostrará erros graciosamente.
# Monte os agents: -v /opt/plex-agents/Stormbringer:/agents/Stormbringer
STORMBRINGER_DIR=/agents/Stormbringer
TIDECALLER_DIR=/agents/TideCaller
TRANSPORTER_DIR=/agents/Transporter

# ── Last.fm (opcional) ────────────────────────────────────────────────────────
# Habilita busca de artistas semelhantes via Last.fm
# Obtenha em: https://www.last.fm/api/account/create
LASTFM_API_KEY=

# ── Debug ─────────────────────────────────────────────────────────────────────
# Ativa logs verbosos (DEBUG) no console e no arquivo de log
# MUSICSAGE_DEBUG=1

# ── Node.js ───────────────────────────────────────────────────────────────────
# NODE_ENV=production
