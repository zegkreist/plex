{
  "name": "@plex-agents/stormbringer",
  "version": "1.0.0",
  "description": "Gerenciamento de downloads via torrent e organização automática para o Plex",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "search": "node src/cli.js search",
    "download": "node src/cli.js download",
    "check-series": "node src/cli.js check-series",
    "track-series": "node src/cli.js track-series",
    "downloads:list": "node src/downloadManagerCli.js list",
    "downloads:status": "node src/downloadManagerCli.js status",
    "downloads:clear": "node src/downloadManagerCli.js clear",
    "downloads:info": "node src/downloadManagerCli.js info",
    "downloads:help": "node src/downloadManagerCli.js help",
    "plex:organize": "node src/plexOrganizer.js",
    "plex:preview": "node src/plexOrganizer.js --dry-run",
    "music:feeds": "node src/cli.js music-feeds",
    "music:browse": "node src/cli.js music-browse",
    "music:track": "node src/cli.js track-music",
    "music:check": "node src/cli.js check-music",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --runInBand --testPathIgnorePatterns=integration",
    "test:integration": "NODE_OPTIONS=--experimental-vm-modules jest --runInBand --testPathPattern=integration",
    "test:all": "NODE_OPTIONS=--experimental-vm-modules jest --runInBand",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch --runInBand --testPathIgnorePatterns=integration",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage --runInBand --testPathIgnorePatterns=integration"
  },
  "keywords": [
    "torrent",
    "download",
    "movies",
    "series",
    "music"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@plex-agents/transporter": "*",
    "axios": "^1.6.2",
    "chalk": "^5.3.0",
    "cheerio": "^1.0.0-rc.12",
    "commander": "^11.1.0",
    "inquirer": "^9.2.12",
    "musicbrainz-api": "^0.9.0",
    "node-cron": "^3.0.3",
    "ora": "^7.0.1",
    "rss-parser": "^3.13.0",
    "sharp": "^0.33.2",
    "torrent-search-api": "^2.1.4",
    "webtorrent": "^2.4.1"
  }
}
