# Configurações do MusicCurator Agent

# URL do servidor Plex
PLEX_URL=http://localhost:32400

# Token de autenticação do Plex
# Para obter: Settings > Account > Plex Web > Show Token (Ctrl+Shift+O)
PLEX_TOKEN=

# Caminho para a biblioteca de música
MUSIC_PATH=/music

# Intervalo entre execuções (em milissegundos)
# 3600000 = 1 hora
CURATOR_INTERVAL=3600000
