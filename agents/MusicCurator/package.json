{
  "name": "music-curator",
  "version": "1.0.0",
  "description": "Agent responsável por organizar e curar a biblioteca de música do Plex",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:unit": "NODE_OPTIONS=--experimental-vm-modules jest tests/unit",
    "test:integration": "NODE_OPTIONS=--experimental-vm-modules jest tests/integration",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "consolidate": "node src/full-library-consolidation.js",
    "fix-tags": "node src/fix-curated-tags.js",
    "fix-tags:dry": "node src/fix-curated-tags.js --dry-run",
    "fix-all-tags": "node src/fix-all-album-tags.js",
    "fix-all-tags:dry": "node src/fix-all-album-tags.js --dry-run"
  },
  "keywords": [
    "plex",
    "music",
    "curator",
    "agent"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@plex-agents/allfather": "file:../AllFather",
    "axios": "^1.6.0",
    "dotenv": "^16.4.0"
  }
}
