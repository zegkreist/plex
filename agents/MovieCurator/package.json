{
  "name": "movie-curator",
  "version": "1.0.0",
  "description": "Agent responsável por organizar e curar a biblioteca de filmes do Plex",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:unit": "NODE_OPTIONS=--experimental-vm-modules jest tests/unit",
    "test:integration": "NODE_OPTIONS=--experimental-vm-modules jest tests/integration",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "curate": "sudo node index.js",
    "curate:dry": "sudo node index.js --dry-run"
  },
  "keywords": ["plex", "movies", "filmes", "curator", "agent"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@plex-agents/allfather": "file:../AllFather",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  }
}
