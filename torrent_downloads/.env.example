# Arquivo de exemplo de variáveis de ambiente
# Copie este arquivo para .env e preencha com suas chaves

# TMDB API Key (The Movie Database)
# Obtenha gratuitamente em: https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Configurações opcionais de teste
TEST_TIMEOUT=60000
TEST_DOWNLOAD_ENABLED=true
